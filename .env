# REConnect Backend Environment Variables
# ─────────────────────────────────────────

# Anthropic Claude API Key (required for agentic features)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DB_HOST=localhost
DB_USER=reconnect_user
DB_PASSWORD=reconnect123
DB_NAME=reconnect

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (for future auth middleware)
JWT_SECRET=reconect_jwt_secret_change_in_production
