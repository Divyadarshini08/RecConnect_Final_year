# REConnect Backend Environment Variables
# ─────────────────────────────────────────

# Google Gemini API Key (required for agentic features)
# Get your key from: https://aistudio.google.com/
# Key format should start with: AIzaSy...
# IMPORTANT: Never commit real API keys to GitHub!
GEMINI_API_KEY=AIzaSy_REPLACE_WITH_YOUR_ACTUAL_GEMINI_API_KEY

# Database
DB_HOST=localhost
DB_USER=reconnect_user
DB_PASSWORD=reconnect123
DB_NAME=reconnect

# Server
PORT=5000
NODE_ENV=development

# JWT Secret (for future auth middleware)
JWT_SECRET=reconect_jwt_secret_change_in_production
